# Backend core
SECRET_KEY=change-me
DEBUG=false
ALLOWED_HOSTS=example.com,api.example.com
SITE_URL=https://api.example.com
MEDIA_URL=/media

# Auth
API_ENABLE_SESSION_AUTH=false
REFRESH_TOKEN_LIFETIME_DAYS=60

# Email
CONTACT_EMAIL_TO=support@example.com
ADMIN_EMAIL_LIST=ops@example.com,dev@example.com
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=no-reply@example.com
EMAIL_HOST_PASSWORD=change-me
EMAIL_USE_TLS=true
DEFAULT_FROM_EMAIL="BS01 <no-reply@example.com>"

# Database (PostgreSQL recommended)
DB_ENGINE=django.db.backends.postgresql
DB_NAME=bs01
DB_USER=bs01
DB_PASSWORD=change-me
DB_HOST=127.0.0.1
DB_PORT=5432
DB_CONN_MAX_AGE=60
# DB_TEST_NAME=test_bs01

# Cache / Redis / Celery
REDIS_URL=redis://127.0.0.1:6379/0
USE_REDIS_CACHE=true
CELERY_BROKER_URL=${REDIS_URL}
CELERY_RESULT_BACKEND=${REDIS_URL}
CELERY_TASK_ALWAYS_EAGER=false
CELERY_TASK_TIME_LIMIT=3600
CELERY_TASK_SOFT_TIME_LIMIT=3300

# CORS / CSRF (IMPORTANT in production)
CORS_ALLOWED_ORIGINS=https://www.example.com,https://admin.example.com
CSRF_TRUSTED_ORIGINS=https://www.example.com,https://admin.example.com
CORS_ALLOW_CREDENTIALS=true

# Security (applies when DEBUG=false)
SECURE_HSTS_SECONDS=31536000
SECURE_SSL_REDIRECT=true
USE_X_FORWARDED_PROTO=true

# Uploads
VIDEO_MAX_SIZE_BYTES=524288000

# DRF throttles (override as needed)
THROTTLE_REGISTER=5/hour
THROTTLE_VERIFY_EMAIL=5/hour
THROTTLE_PASSWORD_RESET=5/hour
THROTTLE_AVATAR_UPLOAD=20/hour
THROTTLE_LOGIN_CODE=30/hour
THROTTLE_LOGIN_PASSWORD=60/hour
THROTTLE_QR_LOGIN=600/hour
THROTTLE_QR_LOGIN_CREATE=120/hour
THROTTLE_QR_LOGIN_STATUS=3600/hour
THROTTLE_QR_LOGIN_CONFIRM=600/hour
THROTTLE_FOLLOW=200/hour
THROTTLE_COMMENTS=120/hour
THROTTLE_HISTORY=3600/hour
THROTTLE_VIDEO_UPLOAD=20/hour
THROTTLE_ANALYTICS=5000/hour
THROTTLE_RECOMMENDATION_FEED=1800/hour
THROTTLE_FOLLOWING_FEED=1800/hour
THROTTLE_FEATURED_FEED=1800/hour
THROTTLE_POPUP_STATS=1800/hour
THROTTLE_CONTACT_SUBMIT=30/hour
THROTTLE_ANON=100/hour
THROTTLE_USER=1000/hour

# Dev helpers
SERVE_MEDIA=false
