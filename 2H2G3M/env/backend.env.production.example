# ==============================================================================
# Django 基础配置
# ==============================================================================
# 安全密钥：用于加密签名，生产环境请务必修改为一个复杂的随机字符串
SECRET_KEY=change-me
# 调试模式：生产环境必须设为 false。开启时会泄露详细错误堆栈，存在安全风险
DEBUG=false

# ==============================================================================
# 数据库配置 (PostgreSQL)
# ==============================================================================
DB_ENGINE=django.db.backends.postgresql
DB_NAME=bs01
DB_USER=bs01
DB_PASSWORD=YourStrongPasswordHere
DB_HOST=127.0.0.1
DB_PORT=5432
DB_CONN_MAX_AGE=60

# ==============================================================================
# 安全与协议配置
# ==============================================================================
# HSTS 过期时间：强制浏览器在指定时间内通过 HTTPS 访问
SECURE_HSTS_SECONDS=31536000
# 是否信任 X-Forwarded-Proto 协议头（在使用 Nginx 转发时有用）
USE_X_FORWARDED_PROTO=true
# 是否强制 HTTPS 跳转：开发环境设为 false
SECURE_SSL_REDIRECT=false

# ==============================================================================
# 邮件服务配置 (SMTP)
# ==============================================================================
# 邮件后端：开发环境可改为 django.core.mail.backends.console.EmailBackend (控制台打印)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# 默认发件人地址
DEFAULT_FROM_EMAIL=mediacms@126.com
# 系统错误通知的发件人
SERVER_EMAIL=mediacms@126.com
# SMTP 服务器地址（以 126 邮箱为例）
EMAIL_HOST=smtp.126.com
# SMTP 端口：通常 SSL 为 465，TLS 为 587
EMAIL_PORT=465
# 邮箱账号
EMAIL_HOST_USER=mediacms@126.com
# 邮箱授权码（非登录密码）
EMAIL_HOST_PASSWORD=SNmuf38VaaZLWuzc
EMAIL_USE_TLS=false
EMAIL_USE_SSL=true
# 管理员接收系统通知的邮箱
ADMIN_EMAIL_LIST=mediacms@126.com
# 邮件标题前缀
EMAIL_SUBJECT_PREFIX=[BS01]
# 联系我们表单的目标接收邮箱
CONTACT_EMAIL_TO=mediacms@126.com

# ==============================================================================
# 业务路径与 URL
# ==============================================================================
# 后端 API 的对外访问基址
SITE_URL=http://api.bs01.local
# 是否由 Django 直接提供媒体文件访问 (生产环境建议交给 Nginx)
SERVE_MEDIA=false

# ==============================================================================
# 频率限制 (Throttling) - 控制单位时间内的请求次数，防刷
# ==============================================================================
# 匿名用户全局限速
THROTTLE_ANON=100000/hour
# 扫码登录相关接口限速
THROTTLE_QR_LOGIN_CREATE=100000/hour
# 扫码状态检查接口限速
THROTTLE_QR_LOGIN_STATUS=1000000/hour
# 扫码确认接口限速
THROTTLE_QR_LOGIN_CONFIRM=2000/hour
# 用户头像/统计信息接口限速
THROTTLE_POPUP_STATS=600/hour

# ==============================================================================
# 登录与验证码风控
# ==============================================================================
# 验证码发送最小间隔（秒）
LOGIN_CODE_MIN_INTERVAL_SECONDS=60
# 单个邮箱每日验证码上限
LOGIN_CODE_DAILY_LIMIT_EMAIL=20
# 单个 IP 每日验证码上限
LOGIN_CODE_DAILY_LIMIT_IP=200

# 验证码登录失败封禁逻辑
LOGIN_CODE_LOGIN_FAIL_WINDOW_SECONDS=600
LOGIN_CODE_LOGIN_FAIL_MAX_TRIES_EMAIL=5
LOGIN_CODE_LOGIN_FAIL_MAX_TRIES_IP=50
LOGIN_CODE_LOGIN_FAIL_COOLDOWN_SECONDS=300

# 密码登录失败封禁逻辑
LOGIN_PASSWORD_FAIL_WINDOW_SECONDS=6000
LOGIN_PASSWORD_FAIL_MAX_TRIES_USERNAME=50
LOGIN_PASSWORD_FAIL_MAX_TRIES_IP=500
LOGIN_PASSWORD_FAIL_COOLDOWN_SECONDS=3000

# ==============================================================================
# 缓存配置 (Redis)
# ==============================================================================
USE_REDIS_CACHE=true
REDIS_URL=redis://127.0.0.1:6379/0
REDIS_MAX_CONNECTIONS=50
CACHE_KEY_PREFIX=bs01   

# ==============================================================================
# Celery
# ==============================================================================
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0
CELERY_TASK_ALWAYS_EAGER=false

# ==============================================================================
# 业务逻辑与安全限制
# ==============================================================================
# 保留用户名（禁止注册），多个以逗号分隔
RESERVED_USERNAMES=admin,root,system,api,auth,login,logout,signup,register,me,Null,null
# 注册是否需要验证码
REGISTRATION_REQUIRE_CAPTCHA=false
# 头像最大字节数 (默认 2MB)
AVATAR_MAX_SIZE_BYTES=2097152
# 视频最大上传字节数 (默认 500MB)
VIDEO_MAX_SIZE_BYTES=524288000

# ==============================================================================
# 国际化与本地化配置
# ==============================================================================
# 语言代码 (如 zh-hans, en-us)
LANGUAGE_CODE=zh-hans
# 时区 (如 Asia/Shanghai, UTC)
TIME_ZONE=Asia/Shanghai

# ==============================================================================
# 认证与跨域 (CORS/CSRF) 配置
# ==============================================================================
# SimpleJWT Access Token 有效期（分钟）- 移动端建议设置较长，如 10080 (7天)
ACCESS_TOKEN_LIFETIME_MINUTES=10080
# SimpleJWT 刷新令牌 (Refresh Token) 有效期（天）
REFRESH_TOKEN_LIFETIME_DAYS=90
# 是否允许跨域请求携带凭证（如 Cookie）
CORS_ALLOW_CREDENTIALS=true
# 允许访问的主机：Django 只处理请求头中 Host 在此列表中的请求
ALLOWED_HOSTS=localhost,127.0.0.1,117.72.192.70,api.bs01.local,web.bs01.local,admin.bs01.local,mobile.bs01.local,127.0.0.1:8000,localhost:8000
# 跨域白名单：允许这些来源的前端页面请求 API
CORS_ALLOWED_ORIGINS=http://web.bs01.local,http://admin.bs01.local
# CSRF 信任来源：通常与 CORS 来源保持一致
CSRF_TRUSTED_ORIGINS=http://web.bs01.local,http://admin.bs01.local
# 是否启用 Session 认证：仅使用 JWT 时建议设为 false 以提高性能和安全性
API_ENABLE_SESSION_AUTH=false
